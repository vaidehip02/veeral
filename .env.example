# =============================================================
# VEERAL — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.
# =============================================================

# ── Supabase ──────────────────────────────────────────────────
# https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API keys
# Use test keys (pk_test_..., sk_test_...) until you go live
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Cloudinary ────────────────────────────────────────────────
# https://cloudinary.com → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Anthropic (Claude API) ────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Google OAuth ──────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Resend (transactional email) ──────────────────────────────
# https://resend.com → API Keys
# TODO: once veeral.com is verified in Resend, update FROM_EMAIL in
#       lib/email/send.ts from 'onboarding@resend.dev' to 'hello@veeral.com'
RESEND_API_KEY=

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
